using App.Business.DTOs.Payments;
using App.Business.Services.Interfaces;
using App.Core.Common;
using Microsoft.AspNetCore.Authorization;
using Microsoft.AspNetCore.Mvc;
using System.Security.Claims;

namespace App.API.Controllers
{
    [Route("api/[controller]")]
    [ApiController]
    [Authorize(Policy = "AdminOrAccountant")]
    public class PaymentsController : ControllerBase
    {
        private readonly IPaymentService _paymentService;

        public PaymentsController(IPaymentService paymentService)
        {
            _paymentService = paymentService;
        }

        // Administrator + Mühasib + Qəbul üzrə əməkdaş — yalnız baxış
        [HttpGet("debtors")]
        [Authorize(Policy = "PaymentView")]
        public async Task<IActionResult> GetDebtors()
        {
            var result = await _paymentService.GetDebtorsAsync();
            return Ok(ApiResponse<IEnumerable<DebtorListItem>>.SuccessResponse(result));
        }

        [HttpGet("child/{childId}")]
        [Authorize(Policy = "PaymentView")]
        public async Task<IActionResult> GetChildPaymentHistory(int childId)
        {
            var result = await _paymentService.GetChildPaymentHistoryAsync(childId);
            return Ok(ApiResponse<IEnumerable<PaymentResponse>>.SuccessResponse(result));
        }

        [HttpGet("report/daily")]
        [Authorize(Policy = "PaymentView")]
        public async Task<IActionResult> GetDailyCashReport([FromQuery] DateOnly date)
        {
            var result = await _paymentService.GetDailyCashReportAsync(date);
            return Ok(ApiResponse<DailyCashReport>.SuccessResponse(result));
        }

        [HttpGet("report/monthly")]
        [Authorize(Policy = "PaymentView")]
        public async Task<IActionResult> GetMonthlyCashReport([FromQuery] int month, [FromQuery] int year)
        {
            var result = await _paymentService.GetMonthlyCashReportAsync(month, year);
            return Ok(ApiResponse<MonthlyCashReport>.SuccessResponse(result));
        }

        [HttpGet("report/group/{groupId}")]
        [Authorize(Policy = "PaymentView")]
        public async Task<IActionResult> GetGroupIncomeReport(int groupId, [FromQuery] int month, [FromQuery] int year)
        {
            var result = await _paymentService.GetGroupIncomeReportAsync(groupId, month, year);
            return Ok(ApiResponse<MonthlyCashReport>.SuccessResponse(result));
        }

        [HttpGet("report/division/{divisionId}")]
        [Authorize(Policy = "PaymentView")]
        public async Task<IActionResult> GetDivisionIncomeReport(int divisionId, [FromQuery] int month, [FromQuery] int year)
        {
            var result = await _paymentService.GetDivisionIncomeReportAsync(divisionId, month, year);
            return Ok(ApiResponse<MonthlyCashReport>.SuccessResponse(result));
        }

        // Administrator + Mühasib — yazma əməliyyatları
        [HttpPost("record")]
        public async Task<IActionResult> RecordPayment([FromBody] RecordPaymentRequest dto)
        {
            var userId = User.FindFirstValue(ClaimTypes.NameIdentifier)!;
            var result = await _paymentService.RecordPaymentAsync(dto, userId);
            return Ok(ApiResponse<PaymentResponse>.SuccessResponse(result, "Ödəniş qeyd edildi."));
        }

        // Yalnız Administrator — aylıq borc yaratma
        [HttpPost("generate-monthly")]
        [Authorize(Policy = "AdminOnly")]
        public async Task<IActionResult> GenerateMonthlyDebts([FromQuery] int month, [FromQuery] int year)
        {
            await _paymentService.GenerateMonthlyDebtsAsync(month, year);
            return Ok(ApiResponse<string>.SuccessResponse($"{month}/{year} üçün borclar yaradıldı."));
        }

        // Administrator + Mühasib — endirim tətbiqi
        [HttpPatch("{id}/discount")]
        public async Task<IActionResult> ApplyDiscount(int id, [FromBody] DiscountRequest dto)
        {
            var result = await _paymentService.ApplyDiscountAsync(id, dto);
            return Ok(ApiResponse<PaymentResponse>.SuccessResponse(result, "Endirim tətbiq edildi."));
        }
    }
}
