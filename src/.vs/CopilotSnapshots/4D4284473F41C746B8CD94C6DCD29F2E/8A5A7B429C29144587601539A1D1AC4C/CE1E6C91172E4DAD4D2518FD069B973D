using App.Core.Entities;
using App.Core.Enums;

namespace App.DAL.Repositories.Interfaces
{
    public interface IChildRepository : IRepository<Child>
    {
        Task<IEnumerable<Child>> GetChildrenWithDetailsAsync();
        Task<IEnumerable<Child>> GetChildrenByGroupIdAsync(int groupId);
        Task<IEnumerable<Child>> SearchChildrenAsync(string searchTerm);
        Task<IEnumerable<Child>> GetActiveChildrenAsync();
        /// <summary>
        /// Returns a filtered, paged set of children with all includes resolved at DB level.
        /// </summary>
        Task<(IEnumerable<Child> Items, int TotalCount)> GetFilteredAsync(
            int? groupId, int? divisionId, ChildStatus? status, ScheduleType? scheduleType,
            int page, int pageSize);
    }
}
