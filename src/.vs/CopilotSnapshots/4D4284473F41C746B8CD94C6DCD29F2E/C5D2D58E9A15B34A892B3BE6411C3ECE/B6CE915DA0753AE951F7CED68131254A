using App.Core.Entities;
using App.Core.Entities.Identity;
using App.Core.Enums;
using Microsoft.AspNetCore.Identity;
using Microsoft.EntityFrameworkCore;

namespace App.DAL.Presistence
{
    /// <summary>
    /// Fills the database with realistic test data.
    /// Triggered only when "SeedTestData": true in appsettings.json.
    /// Idempotent — runs only once (checks if groups already exist).
    /// </summary>
    public static class TestDataSeeder
    {
        private const string ParentPhone    = "+994503954614";
        private const string DefaultPassword = "Test@1234";

        public static async Task SeedTestDataAsync(AppDbContext context, UserManager<User> userManager)
        {
            if (await context.Groups.IgnoreQueryFilters().AnyAsync())
                return;

            var admin = await userManager.FindByEmailAsync("admin@kindergarden.az");
            if (admin == null) return;

            var divisions = await context.Divisions.ToListAsync();
            if (divisions.Count < 2) return;

            var rusDivision = divisions.First(d => d.Name.Contains("Rus"));
            var engDivision = divisions.First(d => d.Name.Contains("İngilis"));

            // 1. İstifadəçilər
            var teachers = await SeedUsersAsync(userManager);

            // 2. Qruplar
            var groups = await SeedGroupsAsync(context, rusDivision.Id, engDivision.Id, teachers);

            // 3. Uşaqlar
            await SeedChildrenAsync(context, groups);

            // 4. Ödənişlər
            await SeedPaymentsAsync(context, admin.Id);

            // 5. Davamiyyət
            await SeedAttendanceAsync(context, admin.Id);
        }

        // ─────────────────────────── İstifadəçilər ───────────────────────────────

        private static async Task<List<User>> SeedUsersAsync(UserManager<User> userManager)
        {
            var userData = new (string First, string Last, string Email, EUserRole Role)[]
            {
                ("Aynur",  "Həsənova",   "teacher1@kindergarden.az",   EUserRole.Teacher),
                ("Gülnar", "Əliyeva",    "teacher2@kindergarden.az",   EUserRole.Teacher),
                ("Nərmin", "Hüseynova",  "teacher3@kindergarden.az",   EUserRole.Teacher),
                ("Sarah",  "Johnson",    "teacher4@kindergarden.az",   EUserRole.Teacher),
                ("Emily",  "Brown",      "teacher5@kindergarden.az",   EUserRole.Teacher),
                ("Anna",   "Smith",      "teacher6@kindergarden.az",   EUserRole.Teacher),
                ("Rəna",   "Quliyeva",   "accountant@kindergarden.az", EUserRole.Accountant),
                ("Zəhra",  "Nəsirzadə", "admission@kindergarden.az",  EUserRole.AdmissionStaff),
            };

            var teachers = new List<User>();

            foreach (var (first, last, email, role) in userData)
            {
                var user = await userManager.FindByEmailAsync(email);
                if (user == null)
                {
                    user = new User
                    {
                        UserName       = email,
                        Email          = email,
                        FirstName      = first,
                        LastName       = last,
                        Role           = role,
                        IsActive       = true,
                        EmailConfirmed = true
                    };
                    await userManager.CreateAsync(user, DefaultPassword);
                    await userManager.AddToRoleAsync(user, role.ToString());
                }

                if (role == EUserRole.Teacher)
                    teachers.Add(user);
            }

            return teachers;
        }

        // ─────────────────────────── Qruplar ─────────────────────────────────────

        private static async Task<List<Group>> SeedGroupsAsync(
            AppDbContext context, int rusId, int engId, List<User> teachers)
        {
            var definitions = new[]
            {
                (Name: "Göyçək",   DivId: rusId, TIdx: 0, Age: "2-3 yaş", Lang: "Russian"),
                (Name: "Günəşli",  DivId: rusId, TIdx: 1, Age: "3-4 yaş", Lang: "Russian"),
                (Name: "Zərif",    DivId: rusId, TIdx: 2, Age: "4-5 yaş", Lang: "Russian"),
                (Name: "Şən",      DivId: rusId, TIdx: 0, Age: "5-6 yaş", Lang: "Russian"),
                (Name: "Sunshine", DivId: engId, TIdx: 3, Age: "2-3 yaş", Lang: "English"),
                (Name: "Rainbow",  DivId: engId, TIdx: 4, Age: "3-4 yaş", Lang: "English"),
                (Name: "Stars",    DivId: engId, TIdx: 5, Age: "4-5 yaş", Lang: "English"),
                (Name: "Moon",     DivId: engId, TIdx: 3, Age: "5-6 yaş", Lang: "English"),
            };

            var groups = definitions.Select(d => new Group
            {
                Name          = d.Name,
                DivisionId    = d.DivId,
                TeacherId     = teachers[d.TIdx].Id,
                MaxChildCount = 15,
                AgeCategory   = d.Age,
                Language      = d.Lang
            }).ToList();

            context.Groups.AddRange(groups);
            await context.SaveChangesAsync();
            return groups;
        }

        // ─────────────────────────── Uşaqlar ─────────────────────────────────────

        private static async Task SeedChildrenAsync(AppDbContext context, List<Group> groups)
        {
            var rnd = new Random(42);

            // Azərbaycan adları (Rus bölməsi)
            string[] azBoyNames  = ["Amir", "Tural", "Rauf", "Elvin", "Murad", "Nihat", "Rəşad", "Vüsal", "Kamil", "Elnur"];
            string[] azGirlNames = ["Aynur", "Günel", "Nərmin", "Leyla", "Səbinə", "Fərəh", "Nuray", "Aytən", "Xədicə", "Gülnar"];
            string[] azLastNames = ["Həsənov", "Əliyev", "Məmmədov", "Hüseynov", "Quliyev", "İsmayılov", "Rəhimov", "Əhmədov", "Nəsirov", "Bağırov"];

            // İngilis adları (İngilis bölməsi)
            string[] enBoyNames  = ["Liam", "Noah", "Oliver", "Lucas", "James", "Ethan", "Logan", "Mason", "Jack", "Leo"];
            string[] enGirlNames = ["Emma", "Olivia", "Ava", "Sophia", "Isabella", "Mia", "Charlotte", "Amelia", "Harper", "Evelyn"];
            string[] enLastNames = ["Smith", "Johnson", "Brown", "Davis", "Miller", "Wilson", "Moore", "Taylor", "Anderson", "Thomas"];

            // Valideyn adları
            string[] parentFirst = ["Anar", "Elnur", "Vüsal", "Tural", "Murad", "Rauf", "Nihat", "Kamil", "Elşən", "Rəşad"];
            string[] parentLast  = ["Həsənov", "Əliyev", "Məmmədov", "Hüseynov", "Quliyev", "İsmayılov", "Rəhimov", "Əhmədov", "Nəsirov", "Bağırov"];

            var now      = DateTime.UtcNow;
            var children = new List<Child>();

            foreach (var group in groups)
            {
                bool isRussian = group.Language == "Russian";
                var  boyNames  = isRussian ? azBoyNames  : enBoyNames;
                var  girlNames = isRussian ? azGirlNames : enGirlNames;
                var  lastNames = isRussian ? azLastNames : enLastNames;

                // "2-3 yaş" → 2
                int minAge = int.Parse(group.AgeCategory[0].ToString());

                for (int i = 0; i < 10; i++)
                {
                    bool isBoy    = i % 2 == 0;
                    var  first    = isBoy ? boyNames[i % boyNames.Length] : girlNames[i % girlNames.Length];
                    var  baseLast = lastNames[i % lastNames.Length];
                    // Qızlara Azərbaycan soyadı son hecası: Həsənov → Həsənova
                    var  last     = (isRussian && !isBoy) ? baseLast + "a" : baseLast;

                    var ageYears  = minAge + rnd.Next(0, 2);
                    var dob       = now.AddYears(-ageYears).AddDays(-rnd.Next(0, 300));

                    var schedType = i % 3 == 0 ? ScheduleType.HalfDay : ScheduleType.FullDay;
                    var fee       = schedType == ScheduleType.FullDay
                                    ? rnd.Next(25, 36) * 10m   // 250–350 AZN
                                    : rnd.Next(15, 21) * 10m;  // 150–200 AZN

                    children.Add(new Child
                    {
                        FirstName        = first,
                        LastName         = last,
                        DateOfBirth      = dob,
                        GroupId          = group.Id,
                        ScheduleType     = schedType,
                        MonthlyFee       = fee,
                        RegistrationDate = now.AddMonths(-rnd.Next(1, 13)),
                        // Son uşaq (i==9) hər qrupda passiv qeydiyyat
                        Status           = i == 9 ? ChildStatus.Inactive : ChildStatus.Active,
                        ParentFullName   = $"{parentFirst[rnd.Next(parentFirst.Length)]} {parentLast[i % parentLast.Length]}",
                        ParentPhone      = ParentPhone,
                        ParentEmail      = $"parent{i + 1}.{group.Name.ToLowerInvariant().Replace(" ", "")}@mail.az"
                    });
                }
            }

            context.Children.AddRange(children);
            await context.SaveChangesAsync();
        }

        // ─────────────────────────── Ödənişlər ───────────────────────────────────

        private static async Task SeedPaymentsAsync(AppDbContext context, string adminId)
        {
            var active = await context.Children
                .Where(c => c.Status == ChildStatus.Active)
                .ToListAsync();

            var now = DateTime.UtcNow;

            // Son 3 ay
            var months = new[]
            {
                (now.AddMonths(-2).Month, now.AddMonths(-2).Year),
                (now.AddMonths(-1).Month, now.AddMonths(-1).Year),
                (now.Month,               now.Year),
            };

            var rnd      = new Random(42);
            var payments = new List<Payment>();

            foreach (var child in active)
            {
                // Hər 5-ci uşağa 10% endirim
                bool   hasDiscount  = child.Id % 5 == 0;
                var    discType     = hasDiscount ? DiscountType.Percentage : DiscountType.None;
                var    discValue    = hasDiscount ? 10m : 0m;
                var    finalAmount  = hasDiscount
                                      ? child.MonthlyFee - child.MonthlyFee * 10m / 100m
                                      : child.MonthlyFee;

                for (int mi = 0; mi < months.Length; mi++)
                {
                    var (month, year) = months[mi];

                    PaymentStatus status;
                    decimal       paid;

                    if (mi == 0)       // 2 ay əvvəl — əksər ödənilib
                    {
                        var r = rnd.Next(6);
                        status = r < 4 ? PaymentStatus.Paid
                               : r == 4 ? PaymentStatus.PartiallyPaid
                               : PaymentStatus.Debt;
                        paid   = status == PaymentStatus.Paid         ? finalAmount
                               : status == PaymentStatus.PartiallyPaid ? Math.Round(finalAmount * 0.8m, 2)
                               : 0m;
                    }
                    else if (mi == 1)  // 1 ay əvvəl — qarışıq
                    {
                        var r = rnd.Next(4);
                        status = r < 2 ? PaymentStatus.Paid
                               : r == 2 ? PaymentStatus.PartiallyPaid
                               : PaymentStatus.Debt;
                        paid   = status == PaymentStatus.Paid         ? finalAmount
                               : status == PaymentStatus.PartiallyPaid ? Math.Round(finalAmount * 0.6m, 2)
                               : 0m;
                    }
                    else               // Bu ay — çoxu borclu
                    {
                        var r = rnd.Next(5);
                        status = r == 0 ? PaymentStatus.Paid
                               : r == 1 ? PaymentStatus.PartiallyPaid
                               : PaymentStatus.Debt;
                        paid   = status == PaymentStatus.Paid         ? finalAmount
                               : status == PaymentStatus.PartiallyPaid ? Math.Round(finalAmount * 0.5m, 2)
                               : 0m;
                    }

                    payments.Add(new Payment
                    {
                        ChildId        = child.Id,
                        Month          = month,
                        Year           = year,
                        OriginalAmount = child.MonthlyFee,
                        DiscountType   = discType,
                        DiscountValue  = discValue,
                        FinalAmount    = finalAmount,
                        PaidAmount     = paid,
                        Status         = status,
                        PaymentDate    = status != PaymentStatus.Debt
                                         ? now.AddDays(-rnd.Next(1, 25))
                                         : null,
                        RecordedById   = adminId
                    });
                }
            }

            context.Payments.AddRange(payments);
            await context.SaveChangesAsync();
        }

        // ─────────────────────────── Davamiyyət ──────────────────────────────────

        private static async Task SeedAttendanceAsync(AppDbContext context, string adminId)
        {
            var active = await context.Children
                .Where(c => c.Status == ChildStatus.Active)
                .ToListAsync();

            var configs    = await context.ScheduleConfigs.ToListAsync();
            var fullDayCfg = configs.FirstOrDefault(c => c.ScheduleType == ScheduleType.FullDay);
            var halfDayCfg = configs.FirstOrDefault(c => c.ScheduleType == ScheduleType.HalfDay);

            // Son 20 iş günü (həftəsonu xaric)
            var workDays = new List<DateOnly>();
            var cursor   = DateOnly.FromDateTime(DateTime.UtcNow);
            while (workDays.Count < 20)
            {
                if (cursor.DayOfWeek != DayOfWeek.Saturday && cursor.DayOfWeek != DayOfWeek.Sunday)
                    workDays.Add(cursor);
                cursor = cursor.AddDays(-1);
            }

            var today       = workDays[0]; // ən yeni iş günü
            var rnd         = new Random(42);
            var attendances = new List<Attendance>();

            foreach (var child in active)
            {
                var cfg = child.ScheduleType == ScheduleType.FullDay ? fullDayCfg : halfDayCfg;
                if (cfg == null) continue;

                foreach (var day in workDays)
                {
                    bool isToday   = day == today;
                    bool isPresent = rnd.Next(100) < 85; // 85% gəliş

                    if (!isPresent)
                    {
                        attendances.Add(new Attendance
                        {
                            ChildId      = child.Id,
                            Date         = day,
                            IsPresent    = false,
                            RecordedById = adminId
                        });
                        continue;
                    }

                    // Gəlmə — 12% gecikir (10–50 dəq)
                    bool isLate  = rnd.Next(100) < 12;
                    var  arrival = isLate
                                   ? cfg.StartTime.AddMinutes(rnd.Next(10, 50))
                                   : cfg.StartTime.AddMinutes(-rnd.Next(0, 10));

                    // Getmə — bugün üçün hələ yoxdur, keçmiş günlər: 8% tez gedir
                    TimeOnly? departure  = null;
                    bool      isEarly    = false;
                    if (!isToday)
                    {
                        isEarly    = rnd.Next(100) < 8;
                        departure  = isEarly
                                     ? cfg.EndTime.AddMinutes(-rnd.Next(30, 90))
                                     : cfg.EndTime.AddMinutes(rnd.Next(0, 15));
                    }

                    attendances.Add(new Attendance
                    {
                        ChildId       = child.Id,
                        Date          = day,
                        IsPresent     = true,
                        ArrivalTime   = arrival,
                        DepartureTime = departure,
                        IsLate        = isLate,
                        IsEarlyLeave  = isEarly,
                        RecordedById  = adminId
                    });
                }
            }

            context.Attendances.AddRange(attendances);
            await context.SaveChangesAsync();
        }
    }
}
