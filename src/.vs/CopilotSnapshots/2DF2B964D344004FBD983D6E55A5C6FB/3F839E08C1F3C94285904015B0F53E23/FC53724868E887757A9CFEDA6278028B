using App.Business.DTOs.Divisions;
using App.Business.Services.Interfaces;
using App.Core.Common;
using Microsoft.AspNetCore.Authorization;
using Microsoft.AspNetCore.Mvc;

namespace App.API.Controllers
{
    [Route("api/[controller]")]
    [ApiController]
    [Authorize]
    public class DivisionsController : ControllerBase
    {
        private readonly IDivisionService _divisionService;

        public DivisionsController(IDivisionService divisionService)
        {
            _divisionService = divisionService;
        }

        [HttpGet]
        public async Task<IActionResult> GetAllDivisions()
        {
            var result = await _divisionService.GetAllDivisionsAsync();
            return Ok(ApiResponse<IEnumerable<DivisionResponse>>.SuccessResponse(result));
        }

        [HttpGet("{id}")]
        public async Task<IActionResult> GetDivisionById(int id)
        {
            var result = await _divisionService.GetDivisionByIdAsync(id);
            return Ok(ApiResponse<DivisionResponse>.SuccessResponse(result));
        }

        [HttpPost]
        [Authorize(Policy = "AdminOnly")]
        public async Task<IActionResult> CreateDivision([FromBody] CreateDivisionRequest dto)
        {
            var result = await _divisionService.CreateDivisionAsync(dto);
            return CreatedAtAction(nameof(GetDivisionById), new { id = result.Id },
                ApiResponse<DivisionResponse>.SuccessResponse(result, "Division created.", 201));
        }

        [HttpPut("{id}")]
        [Authorize(Policy = "AdminOnly")]
        public async Task<IActionResult> UpdateDivision(int id, [FromBody] UpdateDivisionRequest dto)
        {
            var result = await _divisionService.UpdateDivisionAsync(id, dto);
            return Ok(ApiResponse<DivisionResponse>.SuccessResponse(result, "Division updated."));
        }

        [HttpDelete("{id}")]
        [Authorize(Policy = "AdminOnly")]
        public async Task<IActionResult> DeleteDivision(int id)
        {
            await _divisionService.DeleteDivisionAsync(id);
            return Ok(ApiResponse<string>.SuccessResponse("Division deleted."));
        }
    }
}
