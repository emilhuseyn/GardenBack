using App.Core.Entities;
using App.DAL.Presistence;
using App.DAL.Repositories.Interfaces;
using Microsoft.EntityFrameworkCore;

namespace App.DAL.Repositories.Abstractions
{
    public class GroupRepository : Repository<Group>, IGroupRepository
    {
        public GroupRepository(AppDbContext context) : base(context) { }

        public async Task<IEnumerable<Group>> GetGroupsWithDetailsAsync()
        {
            return await DbSet
                .Include(g => g.Division)
                .Include(g => g.Teacher)
                .Include(g => g.Children.Where(c => !c.IsDeleted))
                .ToListAsync();
        }

        public async Task<IEnumerable<Group>> GetGroupsByDivisionAsync(int divisionId)
        {
            return await DbSet
                .Where(g => g.DivisionId == divisionId)
                .Include(g => g.Teacher)
                .Include(g => g.Children.Where(c => !c.IsDeleted))
                .ToListAsync();
        }

        public async Task<IEnumerable<Group>> GetGroupsByTeacherIdAsync(string teacherId)
        {
            return await DbSet
                .Where(g => g.TeacherId == teacherId)
                .ToListAsync();
        }
    }
}
