        // ───── Private helpers ─────

        private async Task SendWhatsAppAsync(string toPhone, string message, int childId)
        {
            // Telefon nömrəsini E.164 formatına gətir: 0501234567 → +994501234567
            var normalized = NormalizePhone(toPhone);
            if (normalized == null)
            {
                _logger.LogWarning("Yanlış telefon formatı, mesaj göndərilmədi: {Phone}", toPhone);
                return;
            }

            var formattedTo = $"whatsapp:{normalized}";

            if (!_isConfigured)
            {
                _logger.LogWarning("[MOCK] WhatsApp → {To}\n{Message}", formattedTo, message);
                await LogNotificationAsync(toPhone, message, childId, isSuccessful: false, error: "Twilio konfiqurasiya edilməyib.");
                return;
            }

            try
            {
                var msg = await MessageResource.CreateAsync(
                    body: message,
                    from: new Twilio.Types.PhoneNumber(_whatsAppFrom),
                    to: new Twilio.Types.PhoneNumber(formattedTo));

                _logger.LogInformation("WhatsApp göndərildi → SID: {Sid}, To: {To}", msg.Sid, formattedTo);
                await LogNotificationAsync(toPhone, message, childId, isSuccessful: true);
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "WhatsApp göndərilə bilmədi → {To}", formattedTo);
                await LogNotificationAsync(toPhone, message, childId, isSuccessful: false, error: ex.Message);
            }
        }

        /// <summary>
        /// Telefon nömrəsini E.164 formatına çevirir.
        /// 0501234567 → +994501234567
        /// 994501234567 → +994501234567
        /// +994501234567 → +994501234567
        /// </summary>
        private static string? NormalizePhone(string phone)
        {
            var digits = new string(phone.Where(char.IsDigit).ToArray());

            return digits.Length switch
            {
                9  => $"+994{digits}",           // 501234567
                10 when digits.StartsWith("0") => $"+994{digits[1..]}", // 0501234567
                12 when digits.StartsWith("994") => $"+{digits}",       // 994501234567
                _ when phone.StartsWith("+") => phone,                  // +994501234567
                _ => null
            };
        }

        private async Task LogNotificationAsync(string phone, string message, int childId, bool isSuccessful, string? error = null)
