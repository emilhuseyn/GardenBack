    public class NotificationService : INotificationService
    {
        private readonly IUnitOfWork _unitOfWork;
        private readonly ILogger<NotificationService> _logger;
        private readonly HttpClient _httpClient;

        private readonly string _idInstance;
        private readonly string _apiToken;
        private readonly bool _isConfigured;

        // Green API base URL
        private string BaseUrl => $"https://api.green-api.com/waInstance{_idInstance}";

        public NotificationService(
            IUnitOfWork unitOfWork,
            ILogger<NotificationService> logger,
            IHttpClientFactory httpClientFactory,
            IConfiguration configuration)
        {
            _unitOfWork = unitOfWork;
            _logger = logger;
            _httpClient = httpClientFactory.CreateClient("GreenApi");

            _idInstance = configuration["GreenApi:IdInstance"] ?? string.Empty;
            _apiToken   = configuration["GreenApi:ApiToken"]   ?? string.Empty;

            _isConfigured = !string.IsNullOrWhiteSpace(_idInstance)
                         && !string.IsNullOrWhiteSpace(_apiToken)
                         && _idInstance != "YOUR_ID_INSTANCE";
        }

        /// <summary>
        /// Bir uşağın borcunu yoxlayır, gecikibsə WhatsApp mesajı göndərir.
        /// </summary>
        public async Task SendPaymentReminderAsync(int childId)
        {
            var child = await _unitOfWork.Children.GetByIdAsync(childId);
            if (child == null) return;

            var debts = (await _unitOfWork.Payments.GetPaymentsByChildAsync(childId))
                .Where(p => p.Status != PaymentStatus.Paid)
                .ToList();

            if (!debts.Any()) return;

            var totalDebt = debts.Sum(p => p.FinalAmount - p.PaidAmount);
            var months    = string.Join(", ", debts.Select(d => $"{d.Month}/{d.Year}"));
            var message   = BuildDebtMessage(child.ParentFullName, $"{child.FirstName} {child.LastName}", totalDebt, months);

            await SendWhatsAppAsync(child.ParentPhone, message, childId);
        }

        /// <summary>
        /// Bütün borclu valideynlərə toplu xatırlatma göndərir.
        /// </summary>
        public async Task SendBulkRemindersToDebtorsAsync()
        {
            var debts   = await _unitOfWork.Payments.GetDebtorsAsync();
            var grouped = debts.GroupBy(p => p.ChildId).ToList();

            _logger.LogInformation("WhatsApp: {Count} borcluya mesaj göndərilir...", grouped.Count);

            foreach (var group in grouped)
                await SendPaymentReminderAsync(group.Key);

            _logger.LogInformation("WhatsApp: Toplu göndərmə tamamlandı.");
        }

        /// <summary>
        /// Cari ay ödənilməmiş bütün uşaqlar üçün gecikmiş ödəniş bildirişi göndərir.
        /// Hangfire tərəfindən avtomatik çağırılır.
        /// </summary>
        public async Task SendOverduePaymentAlertsAsync()
        {
            var now      = DateTime.UtcNow;
            var payments = await _unitOfWork.Payments.GetMonthlyPaymentsAsync(now.Month, now.Year);
            var overdue  = payments.Where(p => p.Status != PaymentStatus.Paid).ToList();

            _logger.LogInformation("WhatsApp gecikmiş bildiriş: {Count} uşaq", overdue.Count);

            foreach (var payment in overdue)
            {
                var child = payment.Child;
                if (child == null) continue;

                var remaining = payment.FinalAmount - payment.PaidAmount;
                var message   = BuildOverdueMessage(
                    child.ParentFullName,
                    $"{child.FirstName} {child.LastName}",
                    remaining,
                    payment.Month,
                    payment.Year);

                await SendWhatsAppAsync(child.ParentPhone, message, child.Id);
            }
        }

        // ───── Private helpers ─────

        private async Task SendWhatsAppAsync(string toPhone, string message, int childId)
        {
            var chatId = ToGreenApiChatId(toPhone);
            if (chatId == null)
            {
                _logger.LogWarning("Yanlış telefon formatı, mesaj göndərilmədi: {Phone}", toPhone);
                return;
            }

            if (!_isConfigured)
            {
                _logger.LogWarning("[MOCK] WhatsApp → {ChatId}\n{Message}", chatId, message);
                await LogNotificationAsync(toPhone, message, childId, isSuccessful: false, error: "Green API konfiqurasiya edilməyib.");
                return;
            }

            try
            {
                // Green API endpoint: POST /waInstance{id}/sendMessage/{token}
                var url  = $"{BaseUrl}/sendMessage/{_apiToken}";
                var body = JsonSerializer.Serialize(new { chatId, message });
                var content = new StringContent(body, Encoding.UTF8, "application/json");

                var response = await _httpClient.PostAsync(url, content);
                var responseBody = await response.Content.ReadAsStringAsync();

                if (response.IsSuccessStatusCode)
                {
                    _logger.LogInformation("WhatsApp göndərildi → {ChatId}", chatId);
                    await LogNotificationAsync(toPhone, message, childId, isSuccessful: true);
                }
                else
                {
                    _logger.LogError("Green API xəta: {Status} → {Body}", (int)response.StatusCode, responseBody);
                    await LogNotificationAsync(toPhone, message, childId, isSuccessful: false, error: responseBody);
                }
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "WhatsApp göndərilə bilmədi → {ChatId}", chatId);
                await LogNotificationAsync(toPhone, message, childId, isSuccessful: false, error: ex.Message);
            }
        }

        /// <summary>
        /// Telefon nömrəsini Green API chatId formatına çevirir.
        /// +994501234567 → 994501234567@c.us
        /// </summary>
        private static string? ToGreenApiChatId(string phone)
        {
            var digits = new string(phone.Where(char.IsDigit).ToArray());

            var e164digits = digits.Length switch
            {
                9  => $"994{digits}",                                    // 501234567
                10 when digits.StartsWith("0") => $"994{digits[1..]}", // 0501234567
                12 when digits.StartsWith("994") => digits,             // 994501234567
                _ => null
            };

            if (e164digits == null && phone.StartsWith("+"))
                e164digits = new string(phone.Where(char.IsDigit).ToArray());

            return e164digits == null ? null : $"{e164digits}@c.us";
        }

        private async Task LogNotificationAsync(string phone, string message, int childId, bool isSuccessful, string? error = null)
        {
            var log = new SMSNotification
            {
                RecipientPhone = phone,
                Message        = isSuccessful ? message : $"[XƏTA: {error}] {message}",
                SentAt         = DateTime.UtcNow,
                IsSuccessful   = isSuccessful,
                ChildId        = childId
            };

            await _unitOfWork.Context.SMSNotifications.AddAsync(log);
            await _unitOfWork.SaveChangesAsync();
        }

        private static string BuildDebtMessage(string parentName, string childName, decimal debt, string months) => $"""
            Hörmətli {parentName},

            "{childName}" adlı uşağınızın aşağıdakı aylara görə ödənişi gecikir:
            📅 Aylar: {months}
            💰 Ümumi borc: {debt:F2} AZN

            Zəhmət olmasa ən qısa müddətdə ödəniş edin.

            Bağ evi administrasiyası
            """;

        private static string BuildOverdueMessage(string parentName, string childName, decimal debt, int month, int year) => $"""
            Hörmətli {parentName},

            "{childName}" adlı uşağınızın {month}/{year} tarixinə olan aylıq ödənişi gecikir.
            💰 Qalan borc: {debt:F2} AZN

            Zəhmət olmasa ödənişi tamamlayın.

            Bağ evi administrasiyası
            """;
    }
}

